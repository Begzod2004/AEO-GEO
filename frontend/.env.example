# Copy to `.env` (or `.env.local`) and adjust as needed. All optional.

# Backend origin the Vite dev proxy forwards `/api` to.
# Default: http://localhost:8000
VITE_PROXY_TARGET=http://localhost:8000

# API base path the app calls (same-origin). Default: /api
# VITE_API_BASE=/api

# Serve the app from an in-memory mock backend for offline visual dev.
# The real code path still calls axios; this only swaps the adapter.
# Set to "true" to enable.
VITE_USE_MOCKS=false
