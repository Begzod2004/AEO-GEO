# Production landing image: build once, run `next start`.
# AEO_BACKEND_URL is read at request time (see lib/waitlist.ts), so it's a
# runtime env var — no rebuild needed to point at the backend.
FROM node:22-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
# Pages are statically prerendered here, so the canonical URLs, sitemap, robots
# and JSON-LD are frozen into the HTML at build time — SITE_URL must be present
# now, not merely at runtime.
ARG SITE_URL
ENV SITE_URL=$SITE_URL
RUN npm run build

FROM node:22-slim
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/package.json /app/package-lock.json ./
RUN npm ci --omit=dev
COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
COPY --from=build /app/next.config.ts ./
EXPOSE 3000
CMD ["npm", "run", "start"]
