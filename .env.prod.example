# AEO.GEO production environment — copy to `.env` NEXT TO docker-compose.prod.yml
# on the server and fill in. Everything marked (required) blocks startup if empty.

# ---- Domains (required) ----
LANDING_DOMAIN=aeo.example.com
APP_DOMAIN=app.aeo.example.com

# ---- Django (required) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# ---- Postgres (required) ----
POSTGRES_PASSWORD=

# ---- AI providers (blank = mock mode; add a key to go live) ----
AEO_MODE=auto
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ---- Billing (structure only in MVP) ----
STRIPE_SECRET_KEY=

# ---- Email (leave EMAIL_BACKEND blank-default = console logs; set SMTP for real mail) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=AEO.GEO <no-reply@aeo.example.com>

# ---- Proxy ----
# 80 in production (certbot upgrades to 443); any free port for local testing.
PROXY_HTTP_PORT=80
