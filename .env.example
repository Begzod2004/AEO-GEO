# AEO.GEO — environment variables.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
# For `docker compose up` you can leave everything blank — the stack runs in
# mock mode with no AI keys. Add keys here to switch a provider to live mode.

# ---- Django ----
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ---- Mode ----
# auto = use a provider live only if its key is set, else mock (default)
# mock = always mock (used in CI / tests)
# live = always attempt real APIs
AEO_MODE=auto

# ---- Data stores ----
# Inside Docker the backend uses internal service names and ignores these.
# On the host these are OPTIONAL: if unset, Django falls back to SQLite +
# localhost, so `manage.py` works with zero infra. Set them only if you run
# your own Postgres/Redis on the host (compose does not publish these ports).
POSTGRES_URL=postgres://aeo:aeo@localhost:5432/aeo
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# ---- AI providers (leave blank to stay in mock mode) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ---- Billing (Stage: models only in MVP) ----
STRIPE_SECRET_KEY=
